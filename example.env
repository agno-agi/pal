# Required (default configured for OpenAI)
OPENAI_API_KEY=sk-***

# Exa MCP (web search, optional auth key)
# EXA_API_KEY=your-exa-key

# Google OAuth (for Gmail + Calendar)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_PROJECT_ID=your-project-id

# Slack (for Slack bot interface)
# SLACK_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret

# Context directory for FileTools
# PAL_CONTEXT_DIR=./context

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
